# ============================================================
# OPERACIONAL5 — Variáveis de ambiente
# ============================================================

# Modo demo/local:
# true  = usa DemoAdapter, sem Supabase real
# false = tenta usar SupabaseAdapter
VITE_DEMO_MODE=true

# Configure apenas na etapa final do Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Futuro: notificações, SMS e e-mail
VITE_FCM_PUBLIC_KEY=
VITE_APP_ENV=local
